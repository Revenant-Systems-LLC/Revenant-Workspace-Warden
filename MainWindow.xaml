<Window x:Class="RevenantWorkspaceWarden.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revenant Workspace Warden" Height="500" Width="420"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="True" WindowStartupLocation="Manual"
        Loaded="Window_Loaded" Closed="Window_Closed"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Metallic gold gradient derived from base #dfbe81 -->
        <LinearGradientBrush x:Key="GoldGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#F5E0B0" Offset="0.0"/>
            <GradientStop Color="#DFBE81" Offset="0.4"/>
            <GradientStop Color="#B8924A" Offset="0.75"/>
            <GradientStop Color="#8B6720" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Teal glow border gradient -->
        <LinearGradientBrush x:Key="TealBorderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#3ad5a1" Offset="0.0"/>
            <GradientStop Color="#20a878" Offset="0.5"/>
            <GradientStop Color="#3ad5a1" Offset="1.0"/>
        </LinearGradientBrush>

        <ControlTemplate x:Key="DarkComboBoxTemplate" TargetType="ComboBox">
            <Grid>
                <ToggleButton Name="ToggleButton"
                              BorderBrush="#3ad5a1" BorderThickness="1"
                              Background="#0a0a0a" Foreground="#3ad5a1"
                              IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                              ClickMode="Press">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border Background="#0a0a0a" BorderBrush="#3ad5a1" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="4,2" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="▼" Foreground="#3ad5a1" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="10"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </ToggleButton.Template>
                </ToggleButton>
                <ContentPresenter Name="ContentSite"
                                  IsHitTestVisible="False"
                                  Content="{TemplateBinding SelectionBoxItem}"
                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                  Margin="6,3,23,3"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left" />
                <Popup Name="Popup"
                       Placement="Bottom"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       AllowsTransparency="True"
                       Focusable="False"
                       PopupAnimation="Slide">
                    <Grid Name="DropDown"
                          SnapsToDevicePixels="True"
                          MinWidth="{TemplateBinding ActualWidth}"
                          MaxHeight="{TemplateBinding MaxDropDownHeight}">
                        <Border x:Name="DropDownBorder"
                                Background="#0a0a0a"
                                BorderThickness="1"
                                BorderBrush="#3ad5a1"/>
                        <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                        </ScrollViewer>
                    </Grid>
                </Popup>
            </Grid>
        </ControlTemplate>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#0a0a0a"/>
            <Setter Property="Foreground" Value="#3ad5a1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#dfbe81"/>
                                <Setter Property="Background" Value="#0a0a0a"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#dfbe81"/>
                                <Setter Property="Background" Value="#0a0a0a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer border: teal glow, very dark teal background -->
    <Border BorderBrush="{StaticResource TealBorderBrush}" BorderThickness="1"
            CornerRadius="4" Background="#F0020e0b" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#3ad5a1" BlurRadius="16" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <!-- Layer 1: Subtle circuit texture -->
            <Image Source="Assets/Circuits.png" Stretch="UniformToFill" Opacity="0.12" Margin="0"/>

            <!-- Layer 2: RWW shield watermark — barely visible, centered -->
            <Image Source="pack://application:,,,/Assets/RWW_SHIELD_alt2.png"
                   Stretch="Uniform" Opacity="0.07"
                   Width="260"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Row 0: Header -->
                    <RowDefinition Height="Auto"/>  <!-- Row 1: Settings -->
                    <RowDefinition Height="*"/>     <!-- Row 2: Chat history -->
                    <RowDefinition Height="Auto"/>  <!-- Row 3: Loading -->
                    <RowDefinition Height="Auto"/>  <!-- Row 4: Input area -->
                    <RowDefinition Height="Auto"/>  <!-- Row 5: Copyright -->
                </Grid.RowDefinitions>

                <!-- ── Header ──────────────────────────────────────────────── -->
                <Border Grid.Row="0" BorderBrush="#3ad5a1" BorderThickness="0,0,0,1" Padding="4,2,4,4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Window controls: top-right, teal -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,0,0,4">
                            <Button Content="—" Width="24" Height="20" FontSize="10"
                                    Background="Transparent" Foreground="#3ad5a1"
                                    BorderThickness="0"
                                    Click="MinimizeBtn_Click"/>
                            <Button Content="⛶" Width="24" Height="20" FontSize="11"
                                    Background="Transparent" Foreground="#3ad5a1"
                                    BorderThickness="0"
                                    Click="MaximizeBtn_Click"/>
                            <Button Content="✕" Width="24" Height="20" FontSize="10"
                                    Background="Transparent" Foreground="#dfbe81"
                                    BorderThickness="0"
                                    Click="CloseBtn_Click"/>
                        </StackPanel>

                        <!-- Workspace Warden wordmark, centered -->
                        <TextBlock Grid.Row="1" Text="REVENANT WORKSPACE WARDEN"
                                   FontFamily="pack://application:,,,/Assets/#Street Reich"
                                   FontSize="22"
                                   Foreground="{StaticResource GoldGradient}"
                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                   Margin="0,0,0,6"/>
                    </Grid>
                </Border>

                <!-- ── Engine Settings ─────────────────────────────────────── -->
                <Expander Name="EngineSettingsExpander" Grid.Row="1" Header="Engine Settings" Foreground="#3ad5a1" Margin="0,5,0,0">
                    <StackPanel Margin="10,5,10,5">
                        <TextBlock Name="PrivacyWarning" Text="Local mode: code stays on this machine." Foreground="#dfbe81" FontStyle="Italic" Margin="0,0,0,10" TextWrapping="Wrap"/>

                        <TextBlock Text="Ollama Base URL:" Foreground="#888888" Margin="0,0,0,2"/>
                        <TextBox Name="OllamaUrlBox" Text="http://localhost:11434"
                                 Background="#0a0a0a" Foreground="White"
                                 BorderBrush="#3ad5a1" Padding="2" Margin="0,0,0,10"
                                 LostFocus="SettingsBox_LostFocus"/>

                        <TextBlock Text="MegaLLM Base URL:" Foreground="#888888" Margin="0,0,0,2"/>
                        <TextBox Name="MegaLlmUrlBox" Text="https://ai.megallm.io"
                                 Background="#0a0a0a" Foreground="White"
                                 BorderBrush="#3ad5a1" Padding="2" Margin="0,0,0,10"
                                 LostFocus="SettingsBox_LostFocus"/>

                        <Button Name="ManageApiKeysBtn" Content="Manage API Keys"
                                Background="#1e1e1e" Foreground="#dfbe81" BorderBrush="#dfbe81" BorderThickness="1"
                                Padding="5" Margin="0,0,0,10" Click="ManageApiKeysBtn_Click"
                                Cursor="Hand"/>

                        <TextBlock Text="LLM Provider:" Foreground="#888888" Margin="0,0,0,2"/>
                        <ComboBox Name="ProviderSelector" Margin="0,0,0,10" Foreground="#3ad5a1" SelectedIndex="0"
                                  Template="{StaticResource DarkComboBoxTemplate}"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                  SelectionChanged="ProviderSelector_SelectionChanged">
                            <ComboBoxItem Content="Ollama" />
                            <ComboBoxItem Content="OpenRouter" />
                            <ComboBoxItem Content="OpenAI" />
                            <ComboBoxItem Content="Anthropic" />
                            <ComboBoxItem Content="Groq" />
                            <ComboBoxItem Content="xAI" />
                            <ComboBoxItem Content="Gemini" />
                            <ComboBoxItem Content="MegaLLM" />
                        </ComboBox>

                        <TextBlock Text="Selected Model:" Foreground="#888888" Margin="0,0,0,2"/>
                        <ComboBox Name="ModelSelector" Margin="0,0,0,10" Foreground="#3ad5a1"
                                  Template="{StaticResource DarkComboBoxTemplate}"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                  SelectionChanged="ModelSelector_SelectionChanged">
                        </ComboBox>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Temperature:" Foreground="#888888"
                                       Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <Slider Grid.Column="1" Name="TempSlider"
                                    Minimum="0.0" Maximum="1.0" Value="0.7"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding ElementName=TempSlider, Path=Value, StringFormat={}{0:0.0}}" 
                                       Foreground="#dfbe81" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock Text="Context Limit (Tokens):" Foreground="#888888" Margin="0,0,0,2"/>
                        <TextBox Name="ContextBox" Text="32768"
                                 Background="#0a0a0a" Foreground="White"
                                 BorderBrush="#3ad5a1" Padding="2"
                                 LostFocus="ContextBox_LostFocus"/>

                        <CheckBox Name="TutorModeCheck"
                                  Content="Tutor Mode (syllabus-aware + teaching)"
                                  Foreground="#3ad5a1" Margin="0,10,0,0"
                                  Checked="TutorModeCheck_Checked"
                                  Unchecked="TutorModeCheck_Unchecked"/>
                    </StackPanel>
                </Expander>


                <!-- ── Chat History ────────────────────────────────────────── -->
                <ScrollViewer Grid.Row="2" Margin="0,10,0,6"
                              Name="ChatScroller" VerticalScrollBarVisibility="Auto">
                    <ItemsControl Name="ChatHistory">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="{Binding Margin}">

                                    <!-- Thinking expander (Ollama reasoning models) -->
                                    <Expander Header="Thinking..."
                                              Foreground="#555555"
                                              Visibility="{Binding HasThinkText, Converter={StaticResource BooleanToVisibilityConverter}}"
                                              Margin="0,0,0,4">
                                        <TextBlock Text="{Binding ThinkText}" Foreground="#888888"
                                                   TextWrapping="Wrap" Margin="10,4,0,4"/>
                                    </Expander>

                                    <!-- Main message text -->
                                    <TextBlock Text="{Binding DisplayText}"
                                               Foreground="{Binding TextColor}"
                                               FontWeight="{Binding TextWeight}"
                                               FontStyle="{Binding TextStyle}"
                                               TextWrapping="Wrap"/>

                                    <!-- Tutor: syllabus area tag -->
                                    <TextBlock Text="{Binding SyllabusArea}"
                                               Foreground="#dfbe81" FontWeight="SemiBold" FontSize="11"
                                               Margin="0,4,0,2"
                                               Visibility="{Binding SyllabusArea, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- Tutor: Before / After code -->
                                    <Expander Header="Before / After" Foreground="#3ad5a1" Margin="0,4,0,2"
                                              Visibility="{Binding BeforeCode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel>
                                            <TextBlock Text="Before:" Foreground="#ff8888" FontSize="10" Margin="0,2"/>
                                            <TextBlock Text="{Binding BeforeCode}" FontFamily="Consolas" FontSize="10"
                                                       Foreground="#e0e0e0" TextWrapping="Wrap"
                                                       Background="#0d0d0d" Padding="4"/>
                                            <TextBlock Text="After:" Foreground="#88ff88" FontSize="10" Margin="0,6,0,2"/>
                                            <TextBlock Text="{Binding AfterCode}" FontFamily="Consolas" FontSize="10"
                                                       Foreground="#e0e0e0" TextWrapping="Wrap"
                                                       Background="#0d0d0d" Padding="4"/>
                                        </StackPanel>
                                    </Expander>

                                    <!-- Tutor: Teaching notes -->
                                    <Expander Header="Teaching Notes" Foreground="#3ad5a1" Margin="0,2,0,4"
                                              Visibility="{Binding TeachingNotes, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="{Binding TeachingNotes}" Foreground="#cccccc"
                                                   TextWrapping="Wrap" FontSize="11" Margin="4"/>
                                    </Expander>

                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- ── Loading Indicator ───────────────────────────────────── -->
                <StackPanel Grid.Row="3" Name="LoadingPanel"
                            Orientation="Horizontal" HorizontalAlignment="Left"
                            Margin="5,0,0,6" Visibility="Collapsed">
                    <ProgressBar IsIndeterminate="True" Width="60" Height="3"
                                 Background="#1a1a1a" Foreground="#3ad5a1"
                                 BorderThickness="0" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Axiom is thinking..."
                               Foreground="#3ad5a1" FontSize="11" FontStyle="Italic"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- ── Input Area ──────────────────────────────────────────── -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Attach (+) button: metallic gold -->
                    <Button Grid.Column="0" Name="AttachBtn" Content="+"
                            Width="30" Height="30"
                            Background="{StaticResource GoldGradient}"
                            Foreground="#0a0a0a" FontWeight="Bold"
                            Click="AttachBtn_Click" Margin="0,0,5,0"
                            ToolTip="Attach File for Review"/>

                    <!-- Mic button removed since voice functionality was taken out -->

                    <!-- Text input: teal border -->
                    <TextBox Grid.Column="2" Name="InputBox"
                             Background="#80010806" Foreground="#e0e0e0"
                             BorderBrush="#3ad5a1" BorderThickness="1"
                             Padding="5" VerticalContentAlignment="Center"
                             KeyDown="InputBox_KeyDown"/>
                </Grid>

                <!-- ── Copyright ───────────────────────────────────────────── -->
                <TextBlock Grid.Row="5"
                           Text="© Revenant Systems LLC"
                           Foreground="#1e5c3e"
                           FontSize="9"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>

            </Grid>
        </Grid>
    </Border>
</Window>
